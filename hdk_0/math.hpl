$int max(int a, int b) {
    int res = a;
    if (a < b) {
        res = b;
    }
    res#return;
}
$int min(int a, int b) {
    int res = a;
    if (a > b) {
        res = b;
    }
    res#return;
}

//fixme
$int power(int val1, int val2) {
    int result = val1;
    times(val2 - 1) result * val1;
    result#return;
}
